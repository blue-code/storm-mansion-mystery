default_platform(:ios)

platform :ios do

  before_all do
    setup_ci if ENV["CI"]
  end

  desc "App Store Connect API 인증"
  private_lane :authenticate do
    app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: ENV["ASC_KEY_PATH"],
      duration: 1200,
      in_house: false
    )
  end

  desc "TestFlight에 새 빌드 업로드"
  lane :beta do
    authenticate

    if ENV["AUTO_INCREMENT_BUILD_NUMBER"] == "true"
      increment_build_number(
        build_number: latest_testflight_build_number(
          app_identifier: "com.digimaru.stormMansionMystery"
        ) + 1,
        xcodeproj: "ios/Runner.xcodeproj"
      )
    end

    get_provisioning_profile(
      app_identifier: "com.digimaru.stormMansionMystery",
      team_id: ENV["TEAM_ID"],
      output_path: "./build",
      filename: "main.mobileprovision",
      ignore_profiles_with_different_name: false
    )
    profile_name = lane_context[SharedValues::SIGH_NAME]
    UI.message("📋 Profile: #{profile_name}")

    update_code_signing_settings(
      use_automatic_signing: false,
      path: "ios/Runner.xcodeproj",
      bundle_identifier: "com.digimaru.stormMansionMystery",
      team_id: ENV["TEAM_ID"],
      profile_name: profile_name,
      code_sign_identity: "Apple Distribution",
      targets: ["Runner"]
    )

    build_app(
      workspace: "ios/Runner.xcworkspace",
      scheme: "Runner",
      clean: true,
      export_method: "app-store",
      export_options: {
        signingStyle: "manual",
        teamID: ENV["TEAM_ID"],
        provisioningProfiles: {
          "com.digimaru.stormMansionMystery" => profile_name
        }
      },
      output_directory: "./build",
      output_name: "StormMansionMystery.ipa"
    )

    upload_to_testflight(
      skip_waiting_for_build_processing: true,
      changelog: changelog_from_git_commits(
        commits_count: 10,
        pretty: "- %s",
        merge_commit_filtering: "exclude_merges"
      )
    )

    clean_build_artifacts
  end

  desc "가격(무료) + 연령등급(12+) Spaceship 으로 일괄 설정"
  lane :setup_app_info do
    authenticate
    require 'spaceship'

    app = Spaceship::ConnectAPI::App.find("com.digimaru.stormMansionMystery")
    UI.user_error!("App not found") unless app

    # 가격: Free (Tier 0)
    UI.message("💰 가격을 무료(USD 0)로 설정")
    begin
      app.update_app_price_tier(app_price_tier_id: "0")
      UI.success("✅ 가격: 무료")
    rescue => e
      UI.important("가격 설정 스킵: #{e.message}")
    end

    # 연령 등급 설문 (AppInfo 기반 - ASC API 1.3+)
    UI.message("📋 연령 등급 설문 작성 (12+ 예상)")
    age_rating_attrs = {
      alcoholTobaccoOrDrugUseOrReferences: "NONE",
      gamblingSimulated: "NONE",
      medicalOrTreatmentInformation: "NONE",
      profanityOrCrudeHumor: "NONE",
      sexualContentGraphicAndNudity: "NONE",
      sexualContentOrNudity: "NONE",
      horrorOrFearThemes: "INFREQUENT_OR_MILD",
      matureOrSuggestiveThemes: "NONE",
      violenceCartoonOrFantasy: "INFREQUENT_OR_MILD",
      violenceRealistic: "NONE",
      violenceRealisticProlongedGraphicOrSadistic: "NONE",
      gunsOrOtherWeapons: "NONE",
      ageAssurance: false,
      parentalControls: false,
      contests: "NONE",
      gambling: false,
      unrestrictedWebAccess: false,
      lootBox: false,
      userGeneratedContent: false,
      advertising: true,
      messagingAndChat: false,
      healthOrWellnessTopics: false
    }

    begin
      app_info = app.fetch_edit_app_info
      UI.user_error!("Edit App Info 가 없습니다 (이미 심사 중일 수 있음)") unless app_info
      decl = app_info.fetch_age_rating_declaration
      Spaceship::ConnectAPI.patch_age_rating_declaration(
        age_rating_declaration_id: decl.id,
        attributes: age_rating_attrs
      )
      UI.success("✅ 연령 등급 설문 저장")
    rescue => e
      UI.error("연령 등급 설정 실패: #{e.message}")
      UI.error(e.backtrace.first(5).join("\n"))
    end
  end

  desc "App Store 메타데이터 + 스크린샷 업로드 (심사 제출 안함)"
  lane :upload_metadata do
    authenticate
    deliver(
      app_identifier: "com.digimaru.stormMansionMystery",
      skip_binary_upload: true,
      skip_screenshots: false,
      overwrite_screenshots: true,
      submit_for_review: false,
      force: true,
      precheck_include_in_app_purchases: false,
      languages: ["ko"]
    )
  end

  desc "App Store 심사 제출 (메타데이터+스크린샷+빌드 자동 선택)"
  lane :release do
    authenticate
    deliver(
      app_identifier: "com.digimaru.stormMansionMystery",
      skip_binary_upload: true,
      skip_screenshots: false,
      overwrite_screenshots: true,
      submit_for_review: true,
      automatic_release: true,
      force: true,
      precheck_include_in_app_purchases: false,
      languages: ["ko"],
      submission_information: {
        add_id_info_uses_idfa: true,
        add_id_info_serves_ads: true,
        add_id_info_tracks_install: true,
        add_id_info_tracks_action: false,
        add_id_info_limits_tracking: true,
        export_compliance_uses_encryption: false,
        content_rights_contains_third_party_content: false
      }
    )
  end

  desc "App Store Connect에 앱 등록 (최초 1회)"
  lane :create_app do
    authenticate
    create_app_online(
      app_identifier: "com.digimaru.stormMansionMystery",
      app_name: "폭풍 저택의 유언",
      language: "ko",
      sku: "com.digimaru.stormMansionMystery.001",
      team_id: ENV["TEAM_ID"],
      platforms: ["ios"]
    )
  end

  desc "빌드만 실행 (업로드 없이)"
  lane :build_only do
    authenticate
    build_app(
      workspace: "ios/Runner.xcworkspace",
      scheme: "Runner",
      clean: true,
      export_method: "app-store",
      export_options: {
        signingStyle: "automatic",
        teamID: ENV["TEAM_ID"]
      },
      export_xcargs: "-allowProvisioningUpdates -authenticationKeyIssuerID #{ENV['ASC_ISSUER_ID']} -authenticationKeyID #{ENV['ASC_KEY_ID']} -authenticationKeyPath #{File.expand_path(ENV['ASC_KEY_PATH'])}",
      output_directory: "./build",
      output_name: "StormMansionMystery.ipa"
    )
  end

end
